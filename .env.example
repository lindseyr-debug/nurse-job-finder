# Copy this file to .env and fill in your own values.
# Never commit .env or share its contents -- it's already in .gitignore.

# The Gmail account that will SEND the text alert (can be your own).
GMAIL_ADDRESS=youraddress@gmail.com

# A Gmail "App Password" -- NOT your normal Gmail password.
# Create one at https://myaccount.google.com/apppasswords (requires 2-Step
# Verification to be turned on first).
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Your phone number's email-to-SMS gateway address.
# Verizon: 9529137325@vtext.com
# AT&T: 9529137325@txt.att.net
# T-Mobile: 9529137325@tmomail.net
PHONE_GATEWAY=9529137325@vtext.com
